  N_NAME_EN    String?   @db.VarChar(50)
  B_DATE       DateTime? @db.Date
  SEX          String?   @db.VarChar(5)
  BE_UNDER     String?   @db.VarChar(50)
  ACTING       String?   @db.VarChar(100)
  IMAGE        String?   @db.VarChar(200)
  NOTE         String?   @db.VarChar(100)
  IS_DEL       String?   @db.Char(1)
  CREATE_DATE  DateTime? @db.DateTime
  CREATE_BY    String?   @db.VarChar(50)
  UPDATE_DATE  DateTime? @db.DateTime
  UPDATE_BY    String?   @db.VarChar(50)
